# Copy this file to .env and fill in real values. main.py fails to start if any are missing.

# VAPID keypair for Web Push. Generate with: vapid --gen (from the py-vapid package)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# Contact address the push service can reach you at if it needs to (required by the Web Push protocol).
VAPID_CLAIM_EMAIL=mailto:you@example.com

# Shared secret for protected endpoints (/api/notify, /api/jobs/daily-check).
# Send it as the X-Cron-Secret header. Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=

# Optional: directory for persisted data (e.g. subscriptions.json). Defaults to the working directory.
# DATA_DIR=
